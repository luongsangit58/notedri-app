{
  "expo": {
    "name": "NoteDri",
    "slug": "notedri-app",
    "scheme": "notedri",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "extra": {
      "eas": {
        "projectId": "92c0bda5-b744-47c5-b06d-12bff12b13f9"
      }
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "NoteDri cần Bluetooth để kết nối với thiết bị OBD của xe bạn"
      }
    },
    "android": {
      "package": "com.notedri",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_ADVERTISE",
        "android.permission.RECORD_AUDIO",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {}
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": false
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "NoteDri cần camera để đọc số ODO và hóa đơn xăng"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "NoteDri cần truy cập ảnh để đọc hóa đơn xăng"
        }
      ],
      "expo-secure-store",
      "expo-localization",
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": false,
          "modes": [
            "central"
          ],
          "bluetoothAlwaysPermission": "NoteDri cần Bluetooth để kết nối với thiết bị OBD của xe bạn"
        }
      ],
      "expo-web-browser",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "NoteDri cần micro để nhận nhập số ODO và số tiền bằng giọng nói",
          "speechRecognitionPermission": "NoteDri cần nhận dạng giọng nói để đọc số ODO và số tiền"
        }
      ]
    ]
  }
}
