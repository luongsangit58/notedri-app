{
  "expo": {
    "name": "NoteDri",
    "slug": "notedri-app",
    "scheme": "notedri",
    "version": "1.1.6",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "extra": {
      "eas": {
        "projectId": "92c0bda5-b744-47c5-b06d-12bff12b13f9"
      },
      "googleWebClientId": "1004530110791-mdsui9ttl0vc43214nilgu564vok8nqs.apps.googleusercontent.com",
      "admob": {
        "androidBannerAdUnitId": "ca-app-pub-3940256099942544/6300978111",
        "iosBannerAdUnitId": "ca-app-pub-3940256099942544/2934735716"
      }
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "NoteDri cần Bluetooth để kết nối với thiết bị OBD2 của xe bạn",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "NoteDri cần vị trí để tự động ghi hành trình khi bạn lái xe",
        "NSLocationAlwaysUsageDescription": "NoteDri cần vị trí nền để ghi hành trình ngay cả khi app đang đóng",
        "UIBackgroundModes": [
          "location",
          "fetch"
        ],
        "NSSpeechRecognitionUsageDescription": "NoteDri cần nhận dạng giọng nói để đọc số ODO và số tiền",
        "NSMicrophoneUsageDescription": "NoteDri cần micro để nhận nhập số ODO và số tiền bằng giọng nói",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.notedri"
    },
    "android": {
      "package": "com.notedri",
      "versionCode": 34,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      },
      "predictiveBackGestureEnabled": false,
      "enableProguardInReleaseBuilds": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": ["BROWSABLE", "DEFAULT"],
          "data": [
            {
              "scheme": "https",
              "host": "notedri.com",
              "pathPrefix": "/connect"
            }
          ]
        }
      ],
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.RECORD_AUDIO",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {}
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "NoteDri cần vị trí để tự động ghi hành trình khi bạn lái xe",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "NoteDri cần camera để đọc số ODO và hóa đơn xăng"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "NoteDri cần truy cập ảnh để đọc hóa đơn xăng"
        }
      ],
      "expo-secure-store",
      "expo-localization",
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": false,
          "modes": [
            "central"
          ],
          "bluetoothAlwaysPermission": "NoteDri cần Bluetooth để kết nối với thiết bị OBD2 của xe bạn"
        }
      ],
      [
        "react-native-nfc-manager",
        {
          "nfcPermission": "NoteDri cần NFC để nhận diện xe khi bạn chạm thẻ NFC"
        }
      ],
      "expo-web-browser",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "NoteDri cần micro để nhận nhập số ODO và số tiền bằng giọng nói",
          "speechRecognitionPermission": "NoteDri cần nhận dạng giọng nói để đọc số ODO và số tiền"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-4780395471669390~3960268170",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ],
      "./withOptionalHardwareFeatures.js",
      "./withNfcIntentFilter.js",
      "./withPictureInPicture.js"
    ]
  }
}
